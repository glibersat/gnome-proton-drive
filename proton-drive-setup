#!/usr/bin/env python3
"""
proton-drive-setup — Proton Drive credential wizard (A2 milestone).

GTK dialog that authenticates via proton-drive-helper (SRP), handles
CAPTCHA challenges with a native WebKitWebView, then stores the session
tokens in the GNOME keyring.  The password is never written to disk.

Requirements: python3-gi
              gir1.2-webkitgtk-6.0  → uses GTK4
              gir1.2-webkit2-4.1    → uses GTK3 (fallback)
              proton-drive-helper  secret-tool
"""

import gi, sys

# Probe WebKit BEFORE requiring any Gtk version: WebKit2 4.1 pulls in GTK3,
# and WebKit 6.0 pulls in GTK4.  Mixing versions raises ImportError.
_webkit_ns = None
_gtk_ver = '4.0'
for _ns, _wkver, _gver in [('WebKit', '6.0', '4.0'), ('WebKit2', '4.1', '3.0')]:
    try:
        gi.require_version(_ns, _wkver)
        _webkit_ns, _gtk_ver = _ns, _gver
        break
    except ValueError:
        pass

gi.require_version('Gtk', _gtk_ver)
from gi.repository import Gtk, GLib

if _webkit_ns:
    import importlib
    WebKit = importlib.import_module(f'gi.repository.{_webkit_ns}')
else:
    WebKit = None

GTK4 = _gtk_ver == '4.0'

import json, os, shutil, socket as _socket, subprocess, tempfile, threading, time, urllib.parse

PROTON_API = 'https://mail.proton.me/api'

# ---------- GTK3/4 shims ----------

def _add(box, child):
    if GTK4:
        box.append(child)
    else:
        box.pack_start(child, False, False, 0)

def _set_child(window, child):
    if GTK4:
        window.set_child(child)
    else:
        window.add(child)

def _password_entry():
    if GTK4:
        e = Gtk.PasswordEntry()
        e.set_show_peek_icon(True)
    else:
        e = Gtk.Entry()
        e.set_visibility(False)
        e.set_input_purpose(Gtk.InputPurpose.PASSWORD)
    return e

def _show_info(parent, title, detail):
    try:                              # GTK 4.10+
        dlg = Gtk.AlertDialog()
        dlg.set_message(title)
        dlg.set_detail(detail)
        dlg.show(parent)
    except AttributeError:            # GTK3 / older GTK4
        dlg = Gtk.MessageDialog(parent=parent, modal=True,
                                message_type=Gtk.MessageType.INFO,
                                buttons=Gtk.ButtonsType.OK, text=title)
        dlg.format_secondary_text(detail)
        dlg.connect('response', lambda d, _: d.destroy())
        dlg.show()

# ---------- helpers ----------

def find_helper():
    here = os.path.dirname(os.path.realpath(__file__))
    for p in [
        os.path.join(here, 'helper', 'proton-drive-helper'),
        '/usr/local/libexec/proton-drive-helper',
        '/usr/libexec/proton-drive-helper',
    ]:
        if os.access(p, os.X_OK):
            return p
    return shutil.which('proton-drive-helper')


def rpc_call(sock_path, method, params):
    s = _socket.socket(_socket.AF_UNIX, _socket.SOCK_STREAM)
    s.connect(sock_path)
    s.sendall((json.dumps({'id': 1, 'method': method, 'params': params}) + '\n').encode())
    data = b''
    while not data.endswith(b'\n'):
        chunk = s.recv(65536)
        if not chunk:
            break
        data += chunk
    s.close()
    return json.loads(data)


def secret_store(label, username, field, value):
    subprocess.run(
        ['secret-tool', 'store', '--label', label,
         'schema', 'org.gnome.proton.drive',
         'username', username, 'field', field],
        input=value.encode(), check=True,
    )

# ---------- window ----------

class SetupWindow(Gtk.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title='Proton Drive — Sign in',
                         default_width=420, default_height=260,
                         resizable=False)
        self._proc = None
        self._sock = None
        self._username = None
        self._password = None

        self._stack = Gtk.Stack()
        self._stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        self._stack.set_transition_duration(150)
        _set_child(self, self._stack)
        self._build_login_page()
        self._build_spinner_page()

    def present(self):
        super().present()
        if not GTK4:
            self.show_all()
            self._err.hide()   # show_all() overrides set_visible(False)

    # ----- login page -----

    def _build_login_page(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        box.set_margin_top(28)
        box.set_margin_bottom(28)
        box.set_margin_start(36)
        box.set_margin_end(36)

        lbl = Gtk.Label()
        lbl.set_markup('<b>Sign in to Proton Drive</b>')
        lbl.set_margin_bottom(4)
        _add(box, lbl)

        self._email = Gtk.Entry()
        self._email.set_placeholder_text('Email address')
        self._email.connect('activate', lambda _: self._pass_w.grab_focus())
        _add(box, self._email)

        self._pass_w = _password_entry()
        if GTK4:
            self._pass_w.connect('activate', self._on_sign_in)
        else:
            self._pass_w.connect('activate', self._on_sign_in)
        _add(box, self._pass_w)

        self._err = Gtk.Label(label='')
        self._err.set_visible(False)
        self._err.set_line_wrap(True)
        _add(box, self._err)

        self._btn = Gtk.Button(label='Sign in')
        if GTK4:
            self._btn.add_css_class('suggested-action')
        self._btn.connect('clicked', self._on_sign_in)
        _add(box, self._btn)

        self._stack.add_named(box, 'login')
        self._stack.set_visible_child_name('login')

    def _build_spinner_page(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_top(40)
        box.set_margin_bottom(40)
        box.set_margin_start(36)
        box.set_margin_end(36)
        self._spinner = Gtk.Spinner()
        self._spinner.set_size_request(48, 48)
        _add(box, self._spinner)
        lbl = Gtk.Label(label='Signing in…')
        _add(box, lbl)
        self._stack.add_named(box, 'spinner')

    def _on_sign_in(self, *_):
        username = self._email.get_text().strip()
        password = self._pass_w.get_text()
        if not username or not password:
            self._show_err('Email and password are required.')
            return
        self._username = username
        self._password = password
        self._err.set_visible(False)
        self._spinner.start()
        self._stack.set_visible_child_name('spinner')
        if not GTK4:
            self._stack.get_visible_child().show_all()
        threading.Thread(target=self._auth_thread, daemon=True).start()

    # ----- captcha page -----

    def _show_captcha(self, hv_token):
        print(f'[setup] _show_captcha called, WebKit={WebKit}', file=sys.stderr)
        try:
            self._show_captcha_inner(hv_token)
        except Exception:
            import traceback; traceback.print_exc()
            self._show_err('Failed to display CAPTCHA — see terminal for details.')

    def _show_captcha_inner(self, hv_token):
        if WebKit is None:
            self._show_err('webkitgtk not installed — cannot display CAPTCHA.\n'
                           'Install gir1.2-webkitgtk-6.0 or gir1.2-webkit2-4.1.')
            return

        ucm = WebKit.UserContentManager()
        ucm.register_script_message_handler('proton')
        ucm.connect('script-message-received::proton', self._on_captcha_token)

        inject = """
window.addEventListener('message', function(e) {
  if (e.data && e.data.type === 'pm_captcha') {
    window.webkit.messageHandlers.proton.postMessage(e.data.token);
  }
});
"""
        inject_time = (getattr(WebKit.UserScriptInjectionTime, 'DOCUMENT_START', None)
                       or WebKit.UserScriptInjectionTime.START)
        try:
            script = WebKit.UserScript(
                inject,
                WebKit.UserContentInjectedFrames.ALL_FRAMES,
                inject_time,
            )
        except TypeError:
            script = WebKit.UserScript(
                inject,
                WebKit.UserContentInjectedFrames.ALL_FRAMES,
                inject_time,
                None, None,
            )
        ucm.add_script(script)

        wv = WebKit.WebView(user_content_manager=ucm)
        wv.set_vexpand(True)
        wv.set_hexpand(True)

        url = (f'{PROTON_API}/core/v4/captcha'
               f'?Token={urllib.parse.quote(hv_token)}&ForceWebMessaging=1')
        wv.load_uri(url)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        note = Gtk.Label(label='Complete the verification to continue.')
        note.set_margin_top(8)
        note.set_margin_bottom(4)
        _add(box, note)
        if GTK4:
            box.append(wv)
        else:
            box.pack_start(wv, True, True, 0)

        # GTK3: widgets must be shown before Stack can display them.
        # show_all() here, before add_named/set_visible_child_name.
        if not GTK4:
            box.show_all()

        self._stack.add_named(box, 'captcha')
        self._stack.set_visible_child_name('captcha')
        self.set_default_size(480, 520)
        self.set_resizable(True)
        print('[setup] captcha page shown', file=sys.stderr)

    def _on_captcha_token(self, _mgr, js_result):
        try:
            token = js_result.get_js_value().to_string()   # WebKit 6
        except AttributeError:
            token = js_result.get_value().to_string()       # WebKit2 4.x
        threading.Thread(target=self._auth_hv_thread, args=(token,), daemon=True).start()

    # ----- RPC threads -----

    def _auth_thread(self):
        try:
            helper = find_helper()
            print(f'[setup] helper: {helper}', file=sys.stderr)
            if not helper:
                GLib.idle_add(self._show_err,
                              'proton-drive-helper not found.\n'
                              'Build it: cd helper && go build -o proton-drive-helper .')
                return

            self._sock = tempfile.mktemp(suffix='.sock', prefix='proton-setup-', dir='/tmp')
            print(f'[setup] socket: {self._sock}', file=sys.stderr)
            self._proc = subprocess.Popen(
                [helper, '--socket', self._sock],
                stdout=subprocess.DEVNULL, stderr=sys.stderr,
            )
            for _ in range(50):
                if os.path.exists(self._sock):
                    break
                time.sleep(0.1)
            else:
                GLib.idle_add(self._show_err, 'Helper failed to start.')
                return

            print('[setup] calling Auth RPC…', file=sys.stderr)
            resp = rpc_call(self._sock, 'Auth',
                            {'username': self._username, 'password': self._password})
            print(f'[setup] Auth response: {resp}', file=sys.stderr)
            self._handle_auth_resp(resp)
        except Exception as e:
            import traceback; traceback.print_exc()
            GLib.idle_add(self._show_err, str(e))

    def _auth_hv_thread(self, hv_token):
        try:
            resp = rpc_call(self._sock, 'AuthWithHV',
                            {'username': self._username, 'password': self._password,
                             'hv_token': hv_token})
            self._handle_auth_resp(resp)
        except Exception as e:
            GLib.idle_add(self._show_err, str(e))

    def _handle_auth_resp(self, resp):
        if 'error' in resp:
            code = resp['error'].get('code')
            if code == -32004:
                token = (resp['error'].get('details') or {}).get('token', '')
                GLib.idle_add(self._show_captcha, token)
            else:
                msg = resp['error'].get('message', 'Authentication failed.')
                GLib.idle_add(self._show_err, msg)
        else:
            GLib.idle_add(self._store_and_finish, resp['result'])

    # ----- success -----

    def _store_and_finish(self, result):
        u = self._username
        try:
            secret_store(f'Proton Drive session UID ({u})', u, 'uid', result['uid'])
            secret_store(f'Proton Drive refresh token ({u})', u,
                         'refresh_token', result['refresh_token'])
            # salted_passphrase is already base64 from JSON; stored as-is so
            # do_mount can g_base64_decode() it directly.
            secret_store(f'Proton Drive key passphrase ({u})', u,
                         'salted_passphrase', result['salted_passphrase'])
        except Exception as e:
            self._show_err(f'Failed to store credentials: {e}')
            return

        self._cleanup()
        _show_info(self, 'Setup complete',
                   f'Signed in as {u}.\n\n'
                   'Proton Drive will appear in Nautilus after the next mount.\n\n'
                   'To mount now:\n  gvfs-mount "proton:///"')
        self.close()

    # ----- utils -----

    def _show_err(self, msg):
        print(f'[setup] error: {msg}', file=sys.stderr)
        self._cleanup()
        self._spinner.stop()
        self._err.set_text(msg)
        self._err.set_visible(True)
        self._btn.set_sensitive(True)
        self._stack.set_visible_child_name('login')

    def _cleanup(self):
        if self._proc:
            self._proc.terminate()
            self._proc = None
        if self._sock and os.path.exists(self._sock):
            os.unlink(self._sock)
            self._sock = None


# ---------- app ----------

class SetupApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id='org.gnome.ProtonDrive.Setup')
        self.connect('activate', lambda app: SetupWindow(app).present())


if __name__ == '__main__':
    sys.exit(SetupApp().run(sys.argv))
